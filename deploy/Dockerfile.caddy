# Stage 1: Build frontend
FROM node:22-alpine AS build
WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci
COPY frontend/ .
RUN npm run build

# Stage 2: Caddy with static frontend
FROM caddy:2-alpine
COPY --from=build /app/dist /srv/frontend
COPY deploy/Caddyfile /etc/caddy/Caddyfile
EXPOSE 80 443
