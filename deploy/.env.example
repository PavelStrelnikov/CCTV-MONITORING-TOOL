# =============================================================================
# CCTV Monitoring Tool — Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all required values.
# Commands for generating secrets are provided in comments.

# === Database ===
POSTGRES_USER=cctv_admin
POSTGRES_PASSWORD=           # REQUIRED: openssl rand -base64 32
POSTGRES_HOST=postgres       # Docker service name (don't change)
POSTGRES_PORT=5432
POSTGRES_DB=cctv_monitoring

# === Encryption ===
ENCRYPTION_KEY=              # REQUIRED: openssl rand -base64 32

# === Authentication (JWT) ===
JWT_SECRET_KEY=              # REQUIRED: openssl rand -base64 64
JWT_EXPIRY_HOURS=24
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=         # REQUIRED: python3 -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD_HERE', bcrypt.gensalt()).decode())"

# === CORS ===
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-domain.com

# === Hikvision SDK ===
HCNETSDK_LIB_PATH=/opt/hikvision-sdk

# === Telegram Bot (optional) ===
TELEGRAM_BOT_TOKEN=
INTERNAL_API_BASE_URL=http://backend:8001
INTERNAL_API_TOKEN=          # openssl rand -base64 32

# === SSL / Domain (Caddy) ===
# Set to your domain for automatic Let's Encrypt SSL
# Use "localhost" for local testing without SSL
DOMAIN=localhost

# === Timezone ===
TELEGRAM_DEFAULT_TIMEZONE=Asia/Jerusalem
